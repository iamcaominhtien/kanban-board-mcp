{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "UI: install dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}/ui"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "UI: dev server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev", "--", "--host", "127.0.0.1"],
      "options": {
        "cwd": "${workspaceFolder}/ui"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": ["relative", "${workspaceFolder}/ui"],
        "pattern": {
          "regexp": "^(?!x)x$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+http://127\\.0\\.0\\.1:\\d+/?"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "UI: build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}/ui"
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}