{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "UI: debug in Chrome",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --host 127.0.0.1",
      "cwd": "${workspaceFolder}/ui",
      "serverReadyAction": {
        "pattern": "Local:\\s+(http://127\\.0\\.0\\.1:\\d+/?)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    }
  ]
}