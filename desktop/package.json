{
  "name": "kanban-board-desktop",
  "version": "1.2.5",
  "description": "Kanban Board MCP Desktop App",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamcaominhtien/kanban-board-mcp.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_DEV=1 electron .",
    "test": "node --test tests/*.test.js",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "sharp": "^0.33.5",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.kanbanboard.app",
    "productName": "Kanban Board",
    "directories": {
      "buildResources": "build",
      "output": "../dist-desktop"
    },
    "files": [
      "main.js",
      "main-helpers.js",
      "preload.js",
      "vscode-setup.js"
    ],
    "extraResources": [
      {
        "from": "../ui/dist",
        "to": "ui/dist",
        "filter": ["**/*", "!**/*.map"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extraResources": [
        {"from": "../dist-python/kanban-server",    "to": "kanban-server"},
        {"from": "../dist-python/kanban-mcp-stdio", "to": "kanban-mcp-stdio"}
      ]
    },
    "win": {
      "target": ["nsis"],
      "extraResources": [
        {"from": "../dist-python/kanban-server.exe",    "to": "kanban-server.exe"},
        {"from": "../dist-python/kanban-mcp-stdio.exe", "to": "kanban-mcp-stdio.exe"}
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
